# Run ./scripts/setup.sh to generate random secrets
JWT_SECRET=change-me

# S3-compatible storage (shared Garage instance)
# Get these from: ./scripts/setup-garage-bucket.sh (run on VPS)
S3_BUCKET=openshelf
S3_ENDPOINT=http://garage:3900
S3_REGION=garage
S3_ACCESS_KEY=
S3_SECRET_KEY=

# For local dev without Garage:
# S3_ACCESS_KEY and S3_SECRET_KEY can be empty — book upload will return 503

# Optional: custom domain for Caddy HTTPS
# DOMAIN=books.example.com
