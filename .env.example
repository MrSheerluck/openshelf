# Required
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string

# Domain (optional: set for custom domain + HTTPS)
# DNS A record must point to your server's IP
DOMAIN=

# Cloudflare R2 (optional: book uploads)
# Uploads work only when R2_ACCOUNT_ID + the S3_* vars are set.
# Leave empty to disable uploads (the rest of the app still works).
S3_BUCKET=openshelf
S3_REGION=auto
R2_ACCOUNT_ID=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Self-hosted S3 (optional, alternative to R2)
# Uncomment and set S3_ENDPOINT to use Garage, MinIO, or any S3-compatible
# service instead of R2. Do not set R2_ACCOUNT_ID at the same time.
# S3_ENDPOINT=http://localhost:3900
