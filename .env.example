# Run ./scripts/setup.sh to generate random JWT_SECRET
JWT_SECRET=change-me

# Cloudflare R2 (S3-compatible)
# Create a bucket named "openshelf" in the R2 dashboard, then:
# - R2_ACCOUNT_ID: Your Cloudflare account ID
# - S3_ACCESS_KEY: R2 access key ID
# - S3_SECRET_KEY: R2 secret access key
R2_ACCOUNT_ID=
S3_BUCKET=openshelf
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Optional: custom domain for Caddy HTTPS
# DOMAIN=books.example.com
